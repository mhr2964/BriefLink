{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brieflink.local/schemas/brief-schema.json",
  "title": "ApiEnvelope",
  "description": "Minimal API response envelope schema for the BriefLink backend foundation.",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["success", "data", "error"],
      "properties": {
        "success": { "const": true },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["service", "status", "version"],
          "properties": {
            "service": { "type": "string", "const": "backend" },
            "status": { "type": "string", "const": "ok" },
            "version": { "type": "string", "const": "v1" }
          }
        },
        "error": { "type": "null" },
        "meta": { "type": "object" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["success", "data", "error"],
      "properties": {
        "success": { "const": false },
        "data": { "type": "null" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "details": { "type": "object" }
          }
        },
        "meta": { "type": "object" }
      }
    }
  ]
}